<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_flf_performance_kpi_today" model="ir.cron">
            <field name="name">FLF Performance: Recompute Today KPI</field>
            <field name="model_id" ref="model_flf_performance_kpi"/>
            <field name="state">code</field>
            <field name="code">model.cron_recompute_today()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">2</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <record id="ir_cron_flf_seed_and_recompute_once" model="ir.cron">
            <field name="name">FLF Performance: Seed demo and recompute once</field>
            <field name="model_id" ref="model_flf_performance_kpi"/>
            <field name="state">code</field>
            <field name="code">model.seed_demo_data(); model.cron_recompute_today()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
