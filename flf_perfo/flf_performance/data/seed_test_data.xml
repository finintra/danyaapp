    <!-- Partners for SLA -->
    <record id="flf_partner_early" model="res.partner">
        <field name="name">EarlyBird LLC</field>
        <field name="company_id" ref="flf_company_1"/>
        <field name="x_flf_deadline_hour">15.5</field> <!-- 15:30 -->
        <field name="x_flf_last_shipment_hour">19.0</field>
        <field name="x_flf_afterhours_credit">1</field>
        <field name="x_flf_big_order_line_count">50</field>
        <field name="x_flf_big_order_qty">150</field>
        <field name="x_flf_use_draft_trigger">1</field>
        <field name="x_flf_responsible_user_ids" eval="[(6,0,[ref('flf_user_c1_1'), ref('flf_user_c1_2')])]"/>
    </record>

    <record id="flf_partner_electrinics" model="res.partner">
        <field name="name">Electrinics LTD</field>
        <field name="company_id" ref="flf_company_1"/>
        <field name="x_flf_deadline_hour">17.5</field> <!-- simple orders day-of by 17:30 -->
        <field name="x_flf_last_shipment_hour">19.0</field>
        <field name="x_flf_afterhours_credit">1</field>
        <field name="x_flf_big_order_line_count">80</field>
        <field name="x_flf_big_order_qty">300</field>
        <field name="x_flf_use_draft_trigger">1</field>
        <field name="x_flf_responsible_user_ids" eval="[(6,0,[ref('flf_user_c1_1'), ref('flf_user_c1_2')])]"/>
    </record>

