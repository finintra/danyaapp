        <field name="primary_partner_id" ref="flf_partner_electrinics"/>
    </record>

    <!-- Truck schedules by weekday -->
    <record id="flf_sched_mon" model="flf.truck.schedule">
        <field name="name">Weekday Monday</field>
        <field name="weekday">mon</field>
    </record>
    <record id="flf_sched_tue" model="flf.truck.schedule">
        <field name="name">Weekday Tuesday</field>
        <field name="weekday">tue</field>
    </record>
    <record id="flf_sched_wed" model="flf.truck.schedule">
        <field name="name">Weekday Wednesday</field>
        <field name="weekday">wed</field>
    </record>
    <record id="flf_sched_thu" model="flf.truck.schedule">
        <field name="name">Weekday Thursday</field>
        <field name="weekday">thu</field>
    </record>
    <record id="flf_sched_fri" model="flf.truck.schedule">
        <field name="name">Weekday Friday</field>
        <field name="weekday">fri</field>
    </record>
    <record id="flf_sched_sat" model="flf.truck.schedule">
        <field name="name">Saturday</field>
        <field name="weekday">sat</field>
    </record>
    <record id="flf_sched_sun" model="flf.truck.schedule">
        <field name="name">Sunday (usually off)</field>
        <field name="weekday">sun</field>
        <field name="active">0</field>
        <field name="note">Usually off. Activate for special cases.</field>
    </record>

    <!-- Weekday slots: 12:30, 15:30, 19:00 -->
    <record id="flf_slot_mon_1230" model="flf.truck.slot">
        <field name="schedule_id" ref="flf_sched_mon"/>
        <field name="departure_time">12:30</field>
        <field name="sequence">10</field>
    </record>
    <record id="flf_slot_mon_1530" model="flf.truck.slot">
        <field name="schedule_id" ref="flf_sched_mon"/>
        <field name="departure_time">15:30</field>
        <field name="sequence">20</field>
    </record>
    <record id="flf_slot_mon_1900" model="flf.truck.slot">
        <field name="schedule_id" ref="flf_sched_mon"/>
        <field name="departure_time">19:00</field>
        <field name="sequence">30</field>
    </record>

