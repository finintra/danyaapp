<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_users_form_inherit_flf_performance" model="ir.ui.view">
        <field name="name">res.users.form.inherit.flf.performance</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet" position="inside">
                <group string="FLF Performance">
                    <field name="x_flf_primary_partner_id" options="{'no_open': True}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
