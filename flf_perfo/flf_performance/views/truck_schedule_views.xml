<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Views for flf.truck.schedule -->
    <record id="view_flf_truck_schedule_tree" model="ir.ui.view">
        <field name="name">flf.truck.schedule.tree</field>
        <field name="model">flf.truck.schedule</field>
        <field name="arch" type="xml">
            <tree string="Truck Schedules" default_order="weekday,date" create="true">
                <field name="name"/>
                <field name="weekday"/>
                <field name="date"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_flf_truck_schedule_form" model="ir.ui.view">
        <field name="name">flf.truck.schedule.form</field>
        <field name="model">flf.truck.schedule</field>
        <field name="arch" type="xml">
            <form string="Truck Schedule">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="weekday"/>
                            <field name="date"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="note" placeholder="Notes"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Slots">
                            <field name="slot_ids" context="{'default_schedule_id': active_id}">
                                <tree editable="bottom">
                                    <field name="departure_time"/>
                                    <field name="is_weekend"/>
                                    <field name="sequence"/>
                                    <field name="active"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action + Menu -->
    <record id="action_flf_truck_schedule" model="ir.actions.act_window">
        <field name="name">Truck Schedules</field>
        <field name="res_model">flf.truck.schedule</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

    <menuitem id="menu_flf_truck_schedule" name="Truck Schedules" parent="flf_performance.menu_flf_performance_configuration" action="action_flf_truck_schedule" sequence="20" groups="flf_performance.group_manager"/>
</odoo>
