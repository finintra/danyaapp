<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- flf.user_config list/form -->
    <record id="view_flf_user_config_tree" model="ir.ui.view">
        <field name="name">flf.user_config.tree</field>
        <field name="model">flf.user_config</field>
        <field name="arch" type="xml">
            <tree string="User Assignments" editable="bottom">
                <field name="company_id"/>
                <field name="user_id"/>
                <field name="primary_partner_id"/>
            </tree>
        </field>
    </record>

    <record id="view_flf_user_config_form" model="ir.ui.view">
        <field name="name">flf.user_config.form</field>
        <field name="model">flf.user_config</field>
        <field name="arch" type="xml">
            <form string="User Assignment">
                <sheet>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="user_id"/>
                            <field name="primary_partner_id"/>
                        </group>
                    </group>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_flf_user_config" model="ir.actions.act_window">
        <field name="name">User Assignments</field>
        <field name="res_model">flf.user_config</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
        <field name="groups_id" eval="[(6,0,[ref('flf_performance.group_manager')])]"/>
    </record>

    <menuitem id="menu_flf_user_config"
              name="User Assignments"
              parent="flf_performance.menu_flf_performance_configuration"
              action="action_flf_user_config"
              sequence="40"
              groups="flf_performance.group_manager"/>
</odoo>
